{
  "log": {
    "loglevel": "warning"
  },
  "routing": {
    "domainStrategy": "IPIfNonMatch",
    "rules": [
      {
        "inboundTag": [
          "tunnel-in"
        ],
        "domain": [
          "example.com"
        ],
        "outboundTag": "direct"
      },
      {
        "inboundTag": [
          "tunnel-in"
        ],
        "outboundTag": "block"
      },
      {
        "port": "80",
        "network": "udp",
        "outboundTag": "block"
      },
      {
        "ip": [
          "geoip:private"
        ],
        "outboundTag": "block"
      }
    ]
  },
  "inbounds": [
    {
      "tag": "tunnel-in",
      "listen": "0.0.0.0",
      "port": 80,
      "protocol": "tunnel",
      "settings": {
        "address": "127.0.0.1",
        "port": 2013,
        "network": "tcp"
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "tls"
        ],
        "routeOnly": true
      }
    },
    {
      "port": 2013, //VLESS+Vision+REALITY 监听端口
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "drEwvgYhS15C", //修改为自己的 UUID
            "flow": "",
            "email": "443@gmail.com"
          }
        ],
        "decryption": "none",
        "fallbacks": [
          {
            "dest": "/dev/shm/uds2023.sock" //回落给 VLESS+XHTTP 监听进程
          }
        ] //回落配置。（选配）
      },
      "streamSettings": {
        "network": "raw",
        "security": "reality",
        "realitySettings": {
          "target": "/dev/shm/uds8443.sock", //转发给自己网站的监听进程
          "xver": 1, //开启 PROXY protocol 发送，发送真实来源 IP 和端口给自己的网站。 1 或 2 表示 PROXY protocol 版本。
          "serverNames": [
            "h3a.example.com" //修改为自己的网站域名
          ], //客户端可用的 serverName 列表，暂不支持 * 通配符。
          "privateKey": "kOsBHSgxhAfCeQIQyJvupiXTmQrMmsqi6y6Wc5OQZXc", //修改为自己执行 ./xray x25519 后生成的一对密钥中私钥
          "shortIds": [
            "d49d578f280fd83a" //若有此项，客户端 shortId 可为空。若不为空，可 0 到 f（0123456789abcdef），长度为 2 的倍数，长度上限为 16 。
          ] //客户端可用的 shortId 列表，可用于区分不同的客户端。
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    },
    {
      "listen": "/dev/shm/uds2023.sock,0666", //VLESS+XHTTP 监听进程及访问权限
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "af7d5cf8-442d-4bb3-8a76-eb367178781d", //修改为自己的 UUID
            "email": "2023@gmail.com"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "xhttpSettings": {
          "path": "" //修改为自己的路径
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct"
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ],
  "policy": {
    "levels": {
      "0": {
        "handshake": 2,
        "connIdle": 120
      }
    }
  }
}
